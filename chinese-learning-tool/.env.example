# AI Provider Configuration
# Choose one: Anthropic Claude or OpenAI GPT
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# AI Model Selection
# For Anthropic: claude-3-5-sonnet-20241022, claude-3-opus-20240229
# For OpenAI: gpt-4, gpt-4-turbo, gpt-3.5-turbo
AI_PROVIDER=anthropic
AI_MODEL=claude-3-5-sonnet-20241022

# Whisper Model Configuration
# Options: tiny, base, small, medium, large
# Larger models are more accurate but slower
WHISPER_MODEL=base

# Audio Settings
SAMPLE_RATE=16000
AUDIO_CHANNELS=1
LANGUAGE=zh-CN
MAX_RECORDING_DURATION=30

# Text-to-Speech Settings
TTS_LANGUAGE=zh-CN
TTS_SLOW=false

# Learning Settings
DIFFICULTY_LEVEL=beginner  # beginner, intermediate, advanced
FEEDBACK_DETAIL=detailed   # simple, detailed, verbose
