# PostgreSQL Database Configuration (same DB as postgres-mcp-server)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=budget
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password_here

# Local directory where uploaded attachments are stored
ATTACHMENT_STORAGE_DIR=./uploads

# Path to the local users file used for admin/user login (see manage_users.py).
# Leave unset to default to users.json next to this app (recommended -- it's
# then found consistently regardless of what directory you launch from).
# DASHBOARD_USERS_FILE=/absolute/path/to/users.json
