# Email Configuration
# SMTP server settings (examples for common providers below)

# Gmail Example:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-specific-password
# FROM_EMAIL=your-email@gmail.com
# SMTP_USE_TLS=true

# Outlook/Hotmail Example:
# SMTP_HOST=smtp-mail.outlook.com
# SMTP_PORT=587
# SMTP_USER=your-email@outlook.com
# SMTP_PASSWORD=your-password
# FROM_EMAIL=your-email@outlook.com
# SMTP_USE_TLS=true

# Generic SMTP Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASSWORD=your-password-here
FROM_EMAIL=your-email@example.com
SMTP_USE_TLS=true

# Report Configuration
# Email address to receive weekly reports
REPORT_TO_EMAIL=recipient@example.com

# Schedule Configuration
# Day of week to send report (monday, tuesday, wednesday, thursday, friday, saturday, sunday)
REPORT_SCHEDULE_DAY=monday

# Time to send report in HH:MM format (24-hour)
REPORT_SCHEDULE_TIME=09:00

# Logging Configuration
LOG_LEVEL=INFO

# MCP Server Configuration (inherited from advisor-agent)
# Make sure these match your postgres-mcp-server settings
POSTGRES_HOST=localhost
POSTGRES_DB=budget
POSTGRES_USER=your_user
POSTGRES_PASSWORD=your_password

# Ollama Configuration (inherited from advisor-agent)
OLLAMA_MODEL=llama3.2
OLLAMA_HOST=http://localhost:11434
