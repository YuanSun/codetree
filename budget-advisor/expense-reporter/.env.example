# Email Configuration
# SMTP server settings (examples for common providers below)

# Gmail Example:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-specific-password
# FROM_EMAIL=your-email@gmail.com
# SMTP_USE_TLS=true

# Outlook/Hotmail Example:
# SMTP_HOST=smtp-mail.outlook.com
# SMTP_PORT=587
# SMTP_USER=your-email@outlook.com
# SMTP_PASSWORD=your-password
# FROM_EMAIL=your-email@outlook.com
# SMTP_USE_TLS=true

# Generic SMTP Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASSWORD=your-password-here
FROM_EMAIL=your-email@example.com
SMTP_USE_TLS=true

# Report Configuration
# Email address(es) to receive reports
# Single recipient:
# REPORT_TO_EMAIL=recipient@example.com
# Multiple recipients (comma-separated):
# REPORT_TO_EMAIL=user1@example.com, user2@example.com, user3@example.com
# Multiple recipients (semicolon-separated):
# REPORT_TO_EMAIL=user1@example.com; user2@example.com; user3@example.com
REPORT_TO_EMAIL=recipient@example.com

# Weekly Report Schedule Configuration
# Enable/disable weekly reports (true/false)
WEEKLY_REPORT_ENABLED=true

# Day of week to send weekly report (monday, tuesday, wednesday, thursday, friday, saturday, sunday)
WEEKLY_REPORT_DAY=monday

# Time to send weekly report in HH:MM format (24-hour)
WEEKLY_REPORT_TIME=09:00

# Monthly Report Schedule Configuration
# Enable/disable monthly reports (true/false)
MONTHLY_REPORT_ENABLED=true

# Time to send monthly report in HH:MM format (24-hour)
# Monthly reports are automatically sent on the 1st of each month
MONTHLY_REPORT_TIME=09:00

# Logging Configuration
LOG_LEVEL=INFO

# Note: Database and Ollama configuration is managed by advisor-agent
# Make sure advisor-agent is properly configured with its own .env file
