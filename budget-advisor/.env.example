# Shared configuration for the Budget Advisor project

# Database Configuration (used by both server and advisor)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=budget
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password_here

# Ollama Configuration (used by advisor)
OLLAMA_MODEL=llama3.2
OLLAMA_HOST=http://localhost:11434

# Logging Configuration
LOG_LEVEL=INFO

# Optional: Enable file logging
# LOG_FILE=budget_advisor.log