# Logging Configuration
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
# For detailed debugging, use:
# LOG_LEVEL=DEBUG

# Ollama Configuration
OLLAMA_MODEL=llama3.2
OLLAMA_HOST=http://localhost:11434

# For remote Ollama instance (e.g., on another Mac in your network):
# OLLAMA_HOST=http://192.168.1.100:11434
# Replace 192.168.1.100 with your Mac's IP address

# MCP Server Configuration
MCP_SERVER_SCRIPT=../postgres-mcp-server/server.py

# Python command (auto-detected by default, but can be overridden)
# PYTHON_CMD=python3
# PYTHON_CMD=/usr/bin/python3.11

# PostgreSQL Database Configuration (passed to MCP server)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=budget
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password_here
